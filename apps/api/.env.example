# NextCrawl API — Environment Variables
# Copy this to .env and fill in values for your local setup.

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite — no Docker required. Path is relative to the prisma/ directory.
DATABASE_URL="file:./dev.db"

# ─── Redis ────────────────────────────────────────────────────────────────────
# Used for BullMQ job queue AND TTL cache. Requires a running Redis instance.
# For local dev: `redis-server` (brew install redis / apt install redis-server)
REDIS_URL="redis://localhost:6379"

# ─── Scraper ──────────────────────────────────────────────────────────────────
# Maximum time (ms) Playwright will wait for a page to load before giving up.
SCRAPE_TIMEOUT_MS=15000

# ─── Cache ────────────────────────────────────────────────────────────────────
# How long (in seconds) a scraped result stays fresh in Redis cache.
# Requests for the same URL within this window return instantly from cache.
CACHE_TTL_SECONDS=3600

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Origin allowed to call the API. In dev, this is the Next.js dashboard.
CORS_ORIGIN="http://localhost:3000"
