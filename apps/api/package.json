{
  "name": "@nextcrawl/api",
  "version": "0.1.0",
  "private": true,
  "description": "NextCrawl scrape/crawl REST API + BullMQ worker",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "install:browsers": "playwright install chromium"
  },
  "dependencies": {
    "@mozilla/readability": "^0.5.0",
    "@nextcrawl/shared": "*",
    "@prisma/client": "^5.14.0",
    "bullmq": "^5.8.4",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "fast-xml-parser": "^5.9.3",
    "ioredis": "^5.3.2",
    "jsdom": "^24.1.0",
    "playwright": "^1.44.1",
    "robots-parser": "^3.0.1",
    "turndown": "^7.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20.14.2",
    "@types/turndown": "^5.0.4",
    "prisma": "^5.14.0",
    "tsx": "^4.15.1",
    "typescript": "^5.4.5"
  }
}
